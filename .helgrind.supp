# pthread_cond_timedwait does not atomically release the mutex in helgrind's
# model — it still tracks the waiting thread as the owner. When another thread
# calls pthread_mutex_lock in dongle_release, helgrind sees a lock acquisition
# on a mutex it believes is held, causing a cascade of false positives and an
# internal assertion crash. All three suppression kinds below are consequences
# of that single modelling gap.

{
   timedwait_lock_grant_false_positive
   Helgrind:Misc
   fun:*
   fun:dongle_release
}

{
   timedwait_race_false_positive
   Helgrind:Race
   fun:dongle_release
}

{
   timedwait_unlock_foreign_false_positive
   Helgrind:UnlockForeign
   fun:*
   fun:dongle_release
}
